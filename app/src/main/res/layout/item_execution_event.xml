<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="8dp"
    android:paddingEnd="12dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/logTimeText"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:textColor="@color/slate_500"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/logStateText"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:textColor="@color/clay_700"
        android:textSize="10sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/logSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ink_900"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/logDetailText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/slate_500"
            android:textSize="10sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>