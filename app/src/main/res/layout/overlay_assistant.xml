<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Collapsed Bubble (1.2x scale, rounded via code) -->
    <FrameLayout
        android:id="@+id/overlay_bubble"
        android:layout_width="67dp"
        android:layout_height="67dp"
        android:background="@android:color/transparent"
        android:visibility="visible"
        android:clickable="true"
        android:focusable="true" />

    <!-- Expanded Voice Panel -->
    <LinearLayout
        android:id="@+id/overlay_panel"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/overlay_panel_bg"
        android:layout_margin="4dp"
        android:visibility="gone"
        android:elevation="8dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/overlay_close_button"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="✕"
                android:textSize="16sp"
                android:textColor="@android:color/darker_gray"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/close_settings_page" />
        </LinearLayout>

        <!-- Voice Input + Speech Output side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- Voice Input -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="start">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/overlay_voice_status_label"
                    android:textSize="11sp"
                    android:textColor="@android:color/darker_gray" />

                <TextView
                    android:id="@+id/overlay_voice_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Idle"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/moss_500" />
            </LinearLayout>

            <!-- Speech Output -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="start">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/overlay_speech_status_label"
                    android:textSize="11sp"
                    android:textColor="@android:color/darker_gray" />

                <TextView
                    android:id="@+id/overlay_speech_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Idle"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/moss_500" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hold to Talk Button -->
        <TextView
            android:id="@+id/overlay_hold_to_talk"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="@string/voice_hold_to_talk"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_chat_hold_to_talk"
            android:layout_marginBottom="10dp" />

        <!-- Playback Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/overlay_stop_speaking_button"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="@string/overlay_stop_speaking_button"
                android:textSize="12sp"
                android:visibility="gone"
                style="?android:attr/buttonBarButtonStyle" />

            <Button
                android:id="@+id/overlay_replay_speaking_button"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/overlay_replay_speaking_button"
                android:textSize="12sp"
                android:visibility="gone"
                style="?android:attr/buttonBarButtonStyle" />

            <Button
                android:id="@+id/overlay_return_button"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/overlay_return_to_main_button"
                android:textSize="11sp"
                style="?android:attr/buttonBarButtonStyle" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>