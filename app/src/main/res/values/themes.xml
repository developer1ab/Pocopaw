<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Pocopaw" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/clay_500</item>
        <item name="colorPrimaryVariant">@color/clay_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/moss_500</item>
        <item name="colorSecondaryVariant">@color/moss_500</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/paper_0</item>
        <item name="colorSurface">@color/panel_0</item>
        <item name="colorOnSurface">@color/ink_900</item>
        <item name="colorError">@color/warning_500</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:navigationBarColor">@color/paper_0</item>
    </style>

    <style name="AppButton.Fixed" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">44dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>
</resources>